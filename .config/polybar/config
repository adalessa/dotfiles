[color]
white = #FFFFFF
red = #e53935
dunno = #5c889c
shade1 = #0f111a
bground = #AA2E3440
fground = #D8DEE9
accent = #31323a
modulefg = #f7f7f7
modulefg-alt = #f7f7f7

[bar/mon1]
dpi = 192
monitor = DisplayPort-0
width                    = 100%
height                   = 25
radius                   = 0
line-size                = 0
bottom                   = false
cursor-click = pointer
wm-restack = bspwm

fixed-center = true
;; the actual font
font-0 = "Hack:size=6:antialias=true;2"
font-1 = "FontAwesome:pixelsize=6:antialias=true:autohint=true;3"
font-2 = "Hack Nerd Font Mono:pixelsize=10:antialias=true:autohint=true;3"

override-redirect = true
offset-x = 0
offset-y = 0
screenchange-reload      = true
throttle-output          = 3
throttle-output-for      = 7
throttle-input-for       = 20
padding-left             = 0
padding-right            = 0
module-margin-left       = 1
module-margin-right      = 1

background = ${color.bground}
foreground = ${color.fground}
overline-size = 2
overline-color = ${color.accent}
modules-left = workspaces
modules-center = title
;modules-right = Playing temp battery volume backlight wifi weather date
modules-right = wifi volume date

